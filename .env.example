# MultiOpenCodeAgent environment

NODE_ENV=production
BACKEND_PORT=3000
FRONTEND_PORT=8080

# Secrets
JWT_SECRET=change-me
OPENCODE_SERVER_PASSWORD=change-me
OPENCODE_SERVER_USERNAME=opencode

# OpenCode AI provider
OPENCODE_API_KEY=

# FireWorks AI provider
FIREWORKS_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_PROXY=

# STT (GigaAM Voice API)
STT_API_URL=https://tts.kulinich.ai/v1/audio/transcriptions
STT_API_KEY=

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Quotas
DEFAULT_TIMEZONE=Europe/Vilnius
DAILY_QUOTA_LIMIT=20
WELCOME_QUOTA=30

# OpenCode global skills directory (default: ../opencode-config/skills relative to workspaces)
OPENCODE_SKILLS_DIR=

# Allow deletion of seeded demo users (e.g. demo@moca.local)
ALLOW_DEMO_DELETION=true
